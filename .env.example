# Tunnel Manager Environment Variables

# SSH Configuration
TUNNEL_IDENTITY_FILE=~/.ssh/id_ed25519

# Inventory (defaults to $XDG_CONFIG_HOME/tunnel-manager/inventory.yml)
# TUNNEL_INVENTORY=~/.config/tunnel-manager/inventory.yml
# TUNNEL_INVENTORY_GROUP=all

# MCP Server Configuration
HOST=0.0.0.0
PORT=9601
TRANSPORT=stdio

# Tool Toggles (all enabled by default)
TM_HOSTS_TOOL=True
TM_REMOTE_TOOL=True
TM_INVENTORY_TOOL=True
TM_OPERATIONS_TOOL=True
TM_SYSTEM_TOOL=True
TM_FILES_TOOL=True
TM_SECURITY_TOOL=True

# Debug
DEBUG=False
PYTHONUNBUFFERED=1
