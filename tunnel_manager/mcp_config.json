{
  "mcpServers": {
    "tunnel-manager-mcp": {
      "command": "uv",
      "args": [
        "run",
        "tunnel-manager-mcp"
      ],
      "env": {
        "TUNNEL_IDENTITY_FILE": "${TUNNEL_IDENTITY_FILE}",
        "HOST_MANAGEMENTTOOL": "${ HOST_MANAGEMENTTOOL:-True }",
        "MISCTOOL": "${ MISCTOOL:-True }",
        "REMOTE_ACCESSTOOL": "${ REMOTE_ACCESSTOOL:-True }",
        "TUNNEL_CERTIFICATE": "${TUNNEL_CERTIFICATE}",
        "TUNNEL_INVENTORY": "${TUNNEL_INVENTORY}",
        "TUNNEL_INVENTORY_GROUP": "${TUNNEL_INVENTORY_GROUP}",
        "TUNNEL_LOG_FILE": "${TUNNEL_LOG_FILE}",
        "TUNNEL_MAX_THREADS": "${TUNNEL_MAX_THREADS}",
        "TUNNEL_PARALLEL": "${TUNNEL_PARALLEL}",
        "TUNNEL_PASSWORD": "${TUNNEL_PASSWORD}",
        "TUNNEL_PROXY_COMMAND": "${TUNNEL_PROXY_COMMAND}",
        "TUNNEL_REMOTE_HOST": "${TUNNEL_REMOTE_HOST}",
        "TUNNEL_REMOTE_PORT": "${TUNNEL_REMOTE_PORT}",
        "TUNNEL_USERNAME": "${TUNNEL_USERNAME}",
        "ADVANCED_FILE_OPERATIONSTOOL": "True",
        "AGENT_DESCRIPTION": "<YOUR_AGENT_DESCRIPTION>",
        "AGENT_SYSTEM_PROMPT": "<YOUR_AGENT_SYSTEM_PROMPT>",
        "DEFAULT_AGENT_NAME": "<YOUR_DEFAULT_AGENT_NAME>",
        "LLM_API_KEY": "<YOUR_LLM_API_KEY>",
        "LLM_BASE_URL": "<YOUR_LLM_BASE_URL>",
        "MCP_URL": "<YOUR_MCP_URL>",
        "MODEL_ID": "<YOUR_MODEL_ID>",
        "OPERATION_MANAGEMENTTOOL": "True",
        "SECURITY_AUDITINGTOOL": "True",
        "SYSTEM_INTELLIGENCETOOL": "True"
      }
    }
  }
}
